# 高德 Web JS API 浏览器端配置
VITE_AMAP_KEY=replace_with_your_amap_key
VITE_AMAP_SECURITY_CODE=replace_with_your_security_code
VITE_AMAP_STYLE=amap://styles/normal

# Node 智能体服务（OPENAI_* 只在服务端读取）
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=replace_with_your_server_key
OPENAI_MODEL=replace_with_your_model
OPENAI_WIRE_API=chat_completions
AI_TOOL_MODE=auto
AI_WEB_SEARCH_MODE=auto
AI_VISION_MODE=auto
AI_REASONING_EFFORT=minimal
AI_MAX_OUTPUT_TOKENS=192
AI_TIMEOUT_MS=18000
HOST=127.0.0.1
PORT=3000
SESSION_STORE_DIR=.runtime
# 生产环境填写后，学生会话与教师场次自动切换为 PostgreSQL 持久化
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/study_learning

# 可选：S3 / R2 / MinIO 兼容证据存储；未配置 S3_BUCKET 时使用本地 uploads/
S3_BUCKET=study-evidence
S3_REGION=auto
S3_ENDPOINT=https://your-s3-compatible-endpoint
S3_ACCESS_KEY_ID=replace_with_access_key
S3_SECRET_ACCESS_KEY=replace_with_secret_key
S3_PREFIX=evidence

# 浏览器通过 Vite 代理访问本地服务
VITE_API_BASE_URL=/api
