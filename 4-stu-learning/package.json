{
  "name": "forbidden-city-study-learning",
  "version": "1.0.0",
  "private": true,
  "description": "故宫治水研学学生端前端项目",
  "type": "module",
  "scripts": {
    "sync:lessons": "node scripts/sync-lessons.mjs",
    "predev": "npm run sync:lessons",
    "dev": "concurrently -k -n api,web -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch-path=server server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "prebuild": "npm run sync:lessons",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.3.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.2",
    "lucide": "^1.25.0",
    "pg": "^8.22.0",
    "zod": "^3.25.76"
  }
}
